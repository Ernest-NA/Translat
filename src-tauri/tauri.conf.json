{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Translat",
  "version": "0.1.0",
  "identifier": "com.ernestna.translat",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Translat",
        "width": 1240,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
